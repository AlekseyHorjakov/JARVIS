      "parameters": {
        "jsCode": "const items = $('Split Out1').all();\n\nconst labels = {\n  name: \"имя\",\n  age: \"возраст\",\n  city: \"город\",\n  country: \"страну\",\n  profession: \"профессию\",\n  job: \"работу\",\n  company: \"компанию\",\n  hobby: \"хобби\",\n  goal: \"цель\",\n  project: \"проект\",\n  language: \"язык\",\n  diabetes_type: \"диабет первого типа\"\n};\n\nconst deleted = items.map(item => {\n  const key = item.json.key;\n  return labels[key] ?? key;\n});\n\nconst reply = deleted.length === 1\n  ? `Хорошо. Я забыл ${deleted[0]}.`\n  : `Хорошо. Я забыл: ${deleted.join(\", \")}.`;\n\nreturn [\n  {\n    json: {\n      reply\n    }\n  }\n];"
