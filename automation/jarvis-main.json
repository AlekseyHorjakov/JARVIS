    {
      "parameters": {
        "jsCode": "const labels = {\n  name: \"👤 Имя\",\n  age: \"🎂 Возраст\",\n  diabetes_type: \"🩺 Диабет\",\n};\n\nconst valueMap = {\n  diabetes_type: {\n    \"type 1 diabetes\": \"1 типа\",\n    \"type 2 diabetes\": \"2 типа\",\n  },\n};\n\nconst lines = [];\nconst other = [];\n\nfor (const item of $input.all()) {\n  const key = item.json.memory_key;\n  const value = item.json.memory_value;\n\n  // Пропускаем пустые записи\n  if (!key || value === undefined || value === null || value === \"\") {\n    continue;\n  }\n\n  let displayValue = value;\n\n  if (valueMap[key] && valueMap[key][value]) {\n    displayValue = valueMap[key][value];\n  }\n\n  if (labels[key]) {\n    lines.push(`${labels[key]}: ${displayValue}`);\n  } else {\n    const safeKey = key.replaceAll(\"_\", \" \");\n    other.push(`• ${safeKey}: ${displayValue}`);\n  }\n}\n\nif (lines.length === 0 && other.length === 0) {\n  return [\n    {\n      json: {\n        reply: \"Пока я ничего о тебе не помню.\",\n      },\n    },\n  ];\n}\n\nlet text = \"Вот что я о тебе помню:\\n\\n\";\n\nif (lines.length) {\n  text += lines.join(\"\\n\");\n}\n\nif (other.length) {\n  text += \"\\n\\n📝 Остальное:\\n\";\n  text += other.join(\"\\n\");\n}\n\nreturn [\n  {\n    json: {\n      reply: text,\n    },\n  },\n];"
      },
